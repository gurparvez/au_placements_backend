# Server
PORT=8000
NODE_ENV=development

# Database
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>

# Authentication
ACCESS_TOKEN_SECRET=<your-secret-key>
ACCESS_TOKEN_EXPIRY=864000

# Cloudinary
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# Email (Resend) — used for recruiter → student inbuilt emailing
# Get a key at https://resend.com. Without it, emails are skipped (dev no-op).
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=Kalgidhar Placements <onboarding@resend.dev>

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://au-placements.vercel.app

# Redis cache (optional) — enables caching + distributed rate limiting.
# Without it the app runs fine, just uncached (graceful no-op). e.g. redis://localhost:6379
REDIS_URL=
CACHE_TTL=60          # seconds — hot lists (openings, companies, students)
CACHE_REF_TTL=300     # seconds — reference data (skills, courses)

# MongoDB connection pool (tune for your instance size / concurrency)
DB_MAX_POOL=20
DB_MIN_POOL=2

# Observability
LOG_LEVEL=            # debug|info|warn|error (default: debug in dev, info in prod)
SLOW_QUERY_MS=200     # log any Mongo query/aggregate slower than this
