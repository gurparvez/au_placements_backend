# Server
PORT=8000
NODE_ENV=development
PUBLIC_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/au_placements

# Authentication
ACCESS_TOKEN_SECRET=<your-secret-key>
ACCESS_TOKEN_EXPIRY=864000

# Local media storage
MEDIA_ROOT=media
MEDIA_URL_PATH=/media

# Local Python OCR for ID card verification
OCR_PYTHON_BIN=python
OCR_SCRIPT_PATH=scripts/ocr_id_card.py
# strict = fail registration if OCR cannot verify
# review = allow registration when OCR is unavailable, for manual review workflows
# disabled = bypass OCR for local development only
ID_CARD_VERIFICATION_MODE=strict

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# Official student email domains (comma-separated)
AU_EMAIL_DOMAINS=akaluniversity.ac.in
EU_EMAIL_DOMAINS=eternaluniversity.edu.in
